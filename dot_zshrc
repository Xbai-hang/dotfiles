# Powerlevel10k instant prompt.
# Keep this near the top. Anything requiring user input should go above it.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# XDG base directories and basic environment.
[[ -f "$HOME/.config/zsh/env.zsh" ]] && source "$HOME/.config/zsh/env.zsh"

# PATH should be loaded before tools/plugins.
[[ -f "$HOME/.config/zsh/path.zsh" ]] && source "$HOME/.config/zsh/path.zsh"

# Oh My Zsh installation path.
export ZSH="$HOME/.oh-my-zsh"

# Theme.
ZSH_THEME="powerlevel10k/powerlevel10k"

# Oh My Zsh behavior.
HYPHEN_INSENSITIVE="true"
HIST_STAMPS="yyyy-mm-dd"
COMPLETION_WAITING_DOTS="true"

# Keep Oh My Zsh updates explicit for reproducible dotfiles.
zstyle ':omz:update' mode reminder
zstyle ':omz:update' frequency 14

# Speed up git status in very large repositories.
# Disable this if you rely heavily on untracked-file status in prompt.
DISABLE_UNTRACKED_FILES_DIRTY="true"

# Plugins.
# Note: zsh-autosuggestions and zsh-syntax-highlighting must be installed in $ZSH_CUSTOM/plugins.
plugins=(
  git
  brew
  macos
  docker
  docker-compose
  golang
  extract
  web-search
  z
  sudo
  zsh-autosuggestions
  zsh-syntax-highlighting
  zsh-history-substring-search
)

source "$ZSH/oh-my-zsh.sh"

# User aliases and functions should be loaded after Oh My Zsh
# so they can override plugin-provided aliases.
[[ -f "$HOME/.config/zsh/aliases.zsh" ]] && source "$HOME/.config/zsh/aliases.zsh"
[[ -f "$HOME/.config/zsh/functions.zsh" ]] && source "$HOME/.config/zsh/functions.zsh"

# Local machine-only config. Do not sync this file with chezmoi.
[[ -f "$HOME/.config/zsh/local.zsh" ]] && source "$HOME/.config/zsh/local.zsh"

# Powerlevel10k config.
[[ -f "$HOME/.p10k.zsh" ]] && source "$HOME/.p10k.zsh"

